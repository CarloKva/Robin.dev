# =============================================================================
# Supabase
# =============================================================================

# Project URL (safe to be public)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Anon key (safe to be public — RLS protects the data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key (SECRET — never use in NEXT_PUBLIC_ or browser code)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Prisma: Supabase connection string with PgBouncer settings
# Get from: Supabase Dashboard → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ccgodxlviculeqsnlgse.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1

# =============================================================================
# Clerk
# =============================================================================

# Publishable key (safe to be public)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Secret key (SECRET — server-side only)
CLERK_SECRET_KEY=sk_test_your_secret_key

# Webhook signing secret (from Clerk Dashboard → Webhooks → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Auth routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/workspace

# =============================================================================
# Orchestrator — Agent VPS (apps/orchestrator, CONTROL_PLANE unset)
# =============================================================================

# Supabase vars used by orchestrator (no NEXT_PUBLIC_ prefix on VPS)
SUPABASE_URL=your_supabase_project_url
# SUPABASE_SERVICE_ROLE_KEY is shared with the block above

# Redis (self-hosted on control-plane VPS, TLS with self-signed cert)
REDIS_URL=rediss://:<password>@<control-plane-ip>:6379

# OPTIONAL: PEM-encoded CA certificate for self-signed Redis TLS.
# If omitted, certificate verification is disabled (connection still encrypted).
# REDIS_CA_CERT=

# Anthropic API key for Claude Code
ANTHROPIC_API_KEY=sk-ant-your-key

# Agent identity
# AGENT_ID must be the UUID of the agent row in the agents table (NOT a human-readable string).
# Local dev (seed data): b0000000-0000-0000-0000-000000000001
# Production: copy the UUID from: SELECT id FROM agents WHERE name = 'Robin Alpha';
AGENT_ID=b0000000-0000-0000-0000-000000000001
AGENT_HOME=/home/agent

# Optional: path to claude binary if not in $PATH
# CLAUDE_BIN=/usr/local/bin/claude

# =============================================================================
# Orchestrator — Control-plane VPS (CONTROL_PLANE=true)
# =============================================================================

# Activates provisioning/deprovisioning workers
CONTROL_PLANE=true

# Hetzner Cloud API — create VPSes
HETZNER_API_TOKEN=fYyErpiyoxaU8fnJmDtyh7pqYu7K2MrepiQTMtaDTwNUth7wvUawWj8CKGjqPi2W

# Hetzner SSH key ID (numeric) — pre-registered in Hetzner Console
# Get with: curl -H "Authorization: Bearer $HETZNER_API_TOKEN" https://api.hetzner.cloud/v1/ssh_keys
HETZNER_SSH_KEY_ID=

# GitHub App credentials — generate installation access tokens
GITHUB_APP_ID=
GITHUB_APP_NAME=robin-dev-app
# base64 of the GitHub App .pem file: base64 -w0 path/to/private-key.pem
GITHUB_APP_PRIVATE_KEY_B64=

# =============================================================================
# Web app — GitHub App (apps/web)
# =============================================================================

# Used by apps/web to redirect to GitHub App install page and verify callbacks
GITHUB_APP_ID=
GITHUB_APP_NAME=robin-dev-app
# Same private key as control-plane — needed to generate install tokens in settings page
GITHUB_APP_PRIVATE_KEY_B64=

# =============================================================================
# Notifications
# =============================================================================

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
RESEND_API_KEY=re_your_resend_api_key
NOTIFY_EMAIL=carlo@example.com

# App URL (used in notification links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# =============================================================================
# Environment variables encryption
# =============================================================================

# AES-256-GCM key for encrypting workspace env vars stored in DB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required by apps/web (encrypt/decrypt via API) and apps/orchestrator (decrypt at execution).
ENV_VARS_ENCRYPTION_KEY=your_64_hex_char_key_here

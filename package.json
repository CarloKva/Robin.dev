{
  "name": "robin-dev",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n web,orch -c blue,green \"npm run dev -w apps/web\" \"npm run dev -w apps/orchestrator\"",
    "lint": "npm run lint -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "build": "npm run build -ws --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.3",
    "typescript": "^5.7.3"
  }
}

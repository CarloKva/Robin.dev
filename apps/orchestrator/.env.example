# ─── Orchestrator VPS Environment ────────────────────────────────────────────
# Copy to .env on the VPS and fill in all values.
#
# Two modes:
#  - Agent VPS (default): CONTROL_PLANE unset — runs task execution worker
#  - Control-plane VPS:   CONTROL_PLANE=true  — runs provisioning workers

# ─── Shared (both modes) ──────────────────────────────────────────────────────

# REQUIRED: Supabase project URL
SUPABASE_URL=

# REQUIRED: Supabase service-role key (bypasses RLS — keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# REQUIRED: Redis connection URL
# Control-plane: rediss://:<password>@127.0.0.1:6379 (local Redis with TLS)
# Agent VPS:     rediss://:<password>@<control-plane-ip>:6379 (remote, TLS)
REDIS_URL=rediss://:<password>@127.0.0.1:6379

# OPTIONAL: PEM-encoded CA certificate for self-signed Redis TLS.
# If omitted, certificate verification is disabled (connection still encrypted).
# REDIS_CA_CERT=

# ─── Agent VPS only (CONTROL_PLANE unset) ────────────────────────────────────

# REQUIRED: UUID of this agent (must exist in agents table)
AGENT_ID=

# REQUIRED: Anthropic API key — passed to every Claude Code subprocess
ANTHROPIC_API_KEY=

# OPTIONAL: Path to claude CLI binary (default: "claude", assumes it's in PATH)
# CLAUDE_BIN=/home/agent/.nvm/versions/node/v22/bin/claude

# OPTIONAL: Agent home directory — repos live at $AGENT_HOME/repos/<workspace_id>/
# Default: /home/agent
# AGENT_HOME=/home/agent

# ─── Control-plane VPS only (CONTROL_PLANE=true) ─────────────────────────────

# Set to "true" to run provisioning/deprovisioning workers instead of task worker
# CONTROL_PLANE=true

# REQUIRED (control-plane): Hetzner Cloud API token
# HETZNER_API_TOKEN=

# OPTIONAL (control-plane): Pre-registered Hetzner SSH key ID (numeric)
# HETZNER_SSH_KEY_ID=

# REQUIRED (control-plane): GitHub App ID
# GITHUB_APP_ID=

# REQUIRED (control-plane): GitHub App private key in base64
# Generate: base64 -w0 path/to/private-key.pem
# GITHUB_APP_PRIVATE_KEY_B64=

# OPTIONAL (control-plane): GitHub App name (slug, not display name).
# Used to set the git author identity on provisioned agent VPSes.
# Agent commits will be attributed to: <GITHUB_APP_NAME>[bot] <GITHUB_APP_ID>+<GITHUB_APP_NAME>[bot]@users.noreply.github.com
# This email must match the GitHub App's noreply address so Vercel (and GitHub) recognise commits as coming from the App.
# GITHUB_APP_NAME=robin-dev

# OPTIONAL (control-plane): Anthropic API key — embedded in cloud-init for new agent VPSes
# (can be the same as ANTHROPIC_API_KEY above or a separate key)
# ANTHROPIC_API_KEY=

# OPTIONAL (control-plane): Override the git repo URL cloned on new agent VPSes
# Default: https://github.com/CarloKva/Robin.dev.git
# ORCHESTRATOR_REPO_URL=

# !! REQUIRED (control-plane): Agents must connect to the control-plane's Redis.
# Without this the orchestrator REFUSES TO START in CONTROL_PLANE mode.
# Agents use BullMQ over this Redis — they must NOT connect to 127.0.0.1.
#
# Also configure the server:
#   sed -i 's/^bind 127.0.0.1.*/bind 0.0.0.0/' /etc/redis/redis.conf
#   systemctl restart redis-server
#   ufw allow 6379/tcp   # or restrict to Hetzner private network
#
# Option A — explicit agent URL (recommended):
# REDIS_URL_AGENT=rediss://:<password>@<control-plane-public-ip>:6379
#
# Option B — derive by replacing host in REDIS_URL:
# REDIS_AGENT_HOST=<control-plane-public-ip>

# OPTIONAL (control-plane): Hetzner snapshot ID for fast provisioning (~30s vs ~5min).
# Create one via POST /api/admin/bake-snapshot, then set this to the returned ID.
# When set, new agents boot from the snapshot instead of running full cloud-init.
# HETZNER_SNAPSHOT_ID=

# OPTIONAL (control-plane): Heartbeat timeout in seconds while waiting for agent to come online.
# Default: 300 (5 min) with snapshot, 720 (12 min) from scratch.
# PROVISIONING_HEARTBEAT_TIMEOUT_SEC=
